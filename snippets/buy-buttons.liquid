{% comment %}
  Renders product buy-buttons.
  Accepts:
  - product: {Object} product object.
  - block: {Object} passing the block information.
  - product_form_id: {String} product form id.
  - section_id: {String} id of section to which this snippet belongs.
  - show_pickup_availability: {Boolean} for the pickup availability. If true the pickup availability is rendered, false - not rendered (optional).

  Usage:
  {% render 'buy-buttons', block: block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: true %}
{% endcomment %}
<div {{ block.shopify_attributes }}>
  {%- if product != blank -%}
    {%- liquid
      assign gift_card_recipient_feature_active = false
      if block.settings.show_gift_card_recipient and product.gift_card?
        assign gift_card_recipient_feature_active = true
      endif

      assign show_dynamic_checkout = false
      if block.settings.show_dynamic_checkout and gift_card_recipient_feature_active == false
        assign show_dynamic_checkout = true
      endif
    -%}
<div class="product-form-wrap">
    <product-form
      class="product-form"
      data-hide-errors="{{ gift_card_recipient_feature_active }}"
      data-section-id="{{ section.id }}"
    >
      <div class="product-form__error-message-wrapper" role="alert" hidden>
        <svg
          aria-hidden="true"
          focusable="false"
          class="icon icon-error"
          viewBox="0 0 13 13"
        >
          <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
          <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
          <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
          <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
        </svg>
        <span class="product-form__error-message"></span>
      </div>

      {%- form 'product',
        product,
        id: product_form_id,
        class: 'form',
        novalidate: 'novalidate',
        data-type: 'add-to-cart-form'
      -%}
        <input
          type="hidden"
          name="id"
          value="{{ product.selected_or_first_available_variant.id }}"
          {% if product.selected_or_first_available_variant.available == false
            or quantity_rule_soldout
            or product.selected_or_first_available_variant == nil
          %}
            disabled
          {% endif %}
          class="product-variant-id"
        >

        {%- if gift_card_recipient_feature_active -%}
          {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
        {%- endif -%}

        <div class="product-form__buttons">
          {%- liquid
            assign check_against_inventory = true
            if product.selected_or_first_available_variant.inventory_management != 'shopify' or product.selected_or_first_available_variant.inventory_policy == 'continue'
              assign check_against_inventory = false
            endif
            if product.selected_or_first_available_variant.quantity_rule.min > product.selected_or_first_available_variant.inventory_quantity and check_against_inventory
              assign quantity_rule_soldout = true
            endif
          -%}

          {%- comment -%} Exam Selector - Only show for CPT products {%- endcomment -%}
          {%- assign show_exam_selector = false -%}
          {%- assign exam_trigger_word = product.metafields.custom.exam_trigger_word | default: 'CPT' -%}
          {%- if product.title contains exam_trigger_word -%}
            {%- assign show_exam_selector = true -%}
          {%- endif -%}

          {%- if show_exam_selector -%}
            <div class="exam-selector-wrapper">
              <button type="button" id="exam-selector-btn-{{ section_id }}" class="exam-selector-btn btn button-yg">
                <span class="btn-label-down">Select Exam</span>
                <span class="btn-label-down">Select Exam</span>
              </button>
              <input type="hidden" name="properties[Exam Option]" id="exam-option-input-{{ section_id }}" value="NASM Certified Personal Trainer (NCCA Accredited Certification Exam)">
              <p class="exam-selected-text" id="exam-selected-text-{{ section_id }}">
                <strong>Selected:</strong> <span>NASM Certified Personal Trainer (NCCA Accredited)</span>
              </p>
            </div>
          {%- endif -%}


          <div class="add-to-cart-row">
            <button
              id="ProductSubmitButton-{{ section_id }}"
              type="submit"
              name="add"
              class="product-form__submit button  btn button-yg"
              {% if product.selected_or_first_available_variant.available == false
                or quantity_rule_soldout
                or product.selected_or_first_available_variant == nil
              %}
                disabled
              {% endif %}
            >
              <span>
                   {%- if product.selected_or_first_available_variant.available == false or quantity_rule_soldout -%}

                        <span class="btn-label-down">Out of Stock</span>
                        <span class="btn-label-down">Out of Stock</span>
                   {%- else -%}
                    <span class="btn-label-down">Add to Cart</span>
              <span class="btn-label-down">Add to Cart</span>
                  {%- endif -%}


              </span>
              {%- render 'loading-spinner' -%}
            </button>

            {% if product.metafields.custom.payment_options %}
              <div class="financing-group">
                <a
                  href="{{ product.metafields.custom.payment_options.value }}"
                  target="_blank"
                  rel="noopener"
                  class="btn button-b financing-btn-inline"
                  data-elective-financing-link
                  data-product-handle="{{ product.handle }}"
                  data-product-id="{{ product.id }}"
                >
                  <span class="btn-label-down">Elective Financing Options</span>
                  <span class="btn-label-down">Elective Financing Options</span>
                </a>
                <div class="tooltip-wrap-inline">
                  <a href="/pages/payment-plan-options" target="_blank" class="payment-options-tooltip"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none"><g clip-path="url(#a)"><path d="M12 2C6.475 2 2 6.475 2 12s4.475 10 10 10 10-4.475 10-10S17.525 2 12 2Zm1 15h-2v-6h2v6Zm0-8h-2V7h2v2Z" /></g><defs><clipPath id="a"><path fill="#fff" d="M0 0h24v24H0z"/></clipPath></defs></svg></a>
                </div>
              </div>
            {% endif %}
          </div>




          
          {%- if show_dynamic_checkout -%}
            {{ form | payment_button }}
          {%- endif -%}
        </div>
      {%- endform -%}
    </product-form>
   </div>

    
    
  {%- else -%}
    <div class="product-form">
      <div class="product-form__buttons form">
        <button
          type="submit"
          name="add"
          class="product-form__submit button button--full-width button--primary"
          disabled
        >
          {{ 'products.product.sold_out' | t }}
        </button>
      </div>
    </div>
  {%- endif -%}

  {%- if show_pickup_availability -%}
    {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}

    {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities
      | where: 'pick_up_enabled', true
    -%}

    <pickup-availability
      class="product__pickup-availabilities quick-add-hidden"
      {% if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %}
        available
      {% endif %}
      data-root-url="{{ routes.root_url }}"
      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
      data-has-only-default-variant="{{ product.has_only_default_variant }}"
      data-product-page-color-scheme="gradient color-{{ section.settings.color_scheme }}"
    >
      <template>
        <pickup-availability-preview class="pickup-availability-preview">
          {% render 'icon-unavailable' %}
          <div class="pickup-availability-info">
            <p class="caption-large">{{ 'products.product.pickup_availability.unavailable' | t }}</p>
            <button class="pickup-availability-button link link--text underlined-link">
              {{ 'products.product.pickup_availability.refresh' | t }}
            </button>
          </div>
        </pickup-availability-preview>
      </template>
    </pickup-availability>

    <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
</div>




        
  <style>
    .product-form{
      display:inline-flex !important;
    }

    /* Add to Cart Row - Horizontal Layout */
    .add-to-cart-row {
      display: flex !important;
      align-items: left;
      gap: 12px;
      flex-wrap: wrap;
      width: 100%;
    }

    .add-to-cart-row .product-form__submit {
      flex: 0 0 auto;
      width: auto !important;
      min-width: 180px;
    }

    /* Financing group wrapper to keep button and icon together */
    .financing-group {
      display: flex;
      align-items: center;
      gap: 8px;
      flex: 1 1 auto;
    }

    .financing-btn-inline {
      color: #141414;
      font-family: Montserrat;
      font-size: 14px;
      font-style: normal;
      font-weight: 700;
      letter-spacing: 1.12px;
      text-decoration-line: none;
      text-transform: uppercase;
      position: relative;
      white-space: nowrap;
      flex: 1 1 auto;
      width: auto !important;
    }

    .financing-btn-inline:before,
    .financing-btn-inline:after {
      content: "";
      position: absolute;
      width: 100%;
      height: 1px;
      bottom: -1px;
      background: #01241E;
    }

    .financing-btn-inline:before {
      left: 0;
    }

    .financing-btn-inline:after {
      right: 0;
      background: #01241E;
      transition: width 0.8s cubic-bezier(0.22, 0.61, 0.36, 1);
    }

    .financing-btn-inline:hover:before {
      background: #01241E;
      width: 0%;
      transition: width 0.5s cubic-bezier(0.22, 0.61, 0.36, 1);
    }

    .financing-btn-inline:hover:after {
      background: transparent;
      width: 0%;
      transition: 0s;
    }

    .tooltip-wrap-inline {
      display: inline-flex;
      align-items: center;
      flex: 0 0 auto;
    }

    /* Override any global button styles that force full width */
    .add-to-cart-row .btn {
      width: auto !important;
      max-width: none !important;
    }

    .product-form-wrap{
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .payment-options-tooltip svg{
      shape-rendering: auto;
      fill: #0F828C;
      transition: 300ms;
    }

    .payment-options-tooltip:hover svg{
      transform: scale(1.2);
      transition: 300ms;
    }

    @media screen and (min-width: 750px) {
      .add-to-cart-row {
        flex-wrap: nowrap;
        align-items: baseline;
      }
    }

    @media screen and (max-width: 749px) {
      .add-to-cart-row {
        gap: 8px;
      }

      .add-to-cart-row .product-form__submit {
        width: 100% !important;
        min-width: auto;
      }

      /* Financing group takes full width but keeps button and icon inline */
      .financing-group {
        width: 100%;
        flex: 1 1 100%;
      }

      .financing-btn-inline {
        padding-top: 16px;
        flex: 1 1 auto;
        width: auto !important;
      }

      .financing-btn-inline .btn-label-down {
        line-height: normal;
      }

      .tooltip-wrap-inline {
        flex-shrink: 0;
      }
    }

    @media screen and (max-width: 364px) {
      .financing-group {
        gap: 6px;
      }

      .financing-btn-inline {
        font-size: 12px;
      }

      .financing-btn-inline .btn-label-down {
        font-size: 12px;
        padding-top: 4px;
      }

      .tooltip-wrap-inline svg {
        width: 20px;
        height: 20px;
      }
    }

/* Exam Selector Styles */
.exam-selector-wrapper {
  width: 100%;
  margin-bottom: 16px;
}

.exam-selector-btn {
  width: 100%;
  margin-bottom: 8px;
  background-color: #D9D9D9;
  color:#000 !important;
}
.exam-selector-btn:hover {
    background: #D9D9D9;
}
.exam-selected-text {
  font-size: 14px;
  color: #01241E;
  margin: 8px 0;
  padding: 8px 12px;
  background: #F2F2E9;
  border-radius: 4px;
}

.exam-selected-text strong {
  font-weight: 700;
}

.exam-selected-text span {
  display: block;
  margin-top: 4px;
  font-size: 13px;
}

/* Modal Styles */
.exam-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.exam-modal-overlay.active {
  display: flex;
}

.exam-modal {
  background: #fff;
  border-radius: 12px;
  max-width: 700px;
  width: 90%;
  max-height: 90vh;
  overflow-y: auto;
  position: relative;
  padding: 32px;
}

.exam-modal-close {
  position: absolute;
  top: 16px;
  right: 16px;
  background: transparent;
  border: none;
  font-size: 28px;
  cursor: pointer;
  color: #141414;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  transition: background 0.2s;
}

.exam-modal-close:hover {
  background: #f0f0f0;
}

.exam-modal-title {
  font-family: var(--font-heading-family);
  font-size: 28px;
  font-weight: 800;
  color: #01241E;
  margin: 0 0 24px 0;
  padding-right: 40px;
}

.exam-option {
  border: 2px solid #d0d0d0;
  border-radius: 8px;
  padding: 20px;
  margin-bottom: 16px;
  cursor: pointer;
  transition: all 0.3s;
}

.exam-option:hover {
  border-color: #0F828C;
  background: #f8f8f8;
}

.exam-option.selected {
  border-color: #C1FF72;
  background: #f0ffe0;
}

.exam-option-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12px;
}

.exam-option-radio {
  width: 20px;
  height: 20px;
  min-width: 20px;
  border: 2px solid #0F828C;
  border-radius: 50%;
  margin-right: 12px;
  margin-top: 2px;
  position: relative;
  transition: all 0.2s;
}

.exam-option.selected .exam-option-radio {
  border-color: #0F828C;
  background: #C1FF72;
}

.exam-option.selected .exam-option-radio::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8px;
  height: 8px;
  background: #01241E;
  border-radius: 50%;
}

.exam-option-name {
  font-family: var(--font-heading-family);
  font-size: 18px;
  font-weight: 700;
  color: #01241E;
  margin: 0 0 8px 0;
  flex: 1;
}

.exam-option-description {
  font-size: 14px;
  line-height: 1.6;
  color: #141414;
  margin: 0;
  padding-left: 32px;
}

.exam-modal-footer {
  margin-top: 24px;
  display: flex;
  gap: 12px;
  justify-content: flex-end;
}

.exam-modal-btn {
  padding: 12px 24px;
  border-radius: 8px;
  font-family: Montserrat;
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  cursor: pointer;
  border: none;
  transition: all 0.3s;
}

.exam-modal-cancel {
  background: transparent;
  color: #141414;
  border: 2px solid #d0d0d0;
}

.exam-modal-cancel:hover {
  background: #f0f0f0;
}

.exam-modal-confirm {
  background: #C1FF72;
  color: #01241E;
}

.exam-modal-confirm:hover {
  background: #b0ef62;
}

@media screen and (max-width: 749px) {
  .exam-modal {
    padding: 24px 20px;
  }

  .exam-modal-title {
    font-size: 22px;
  }

  .exam-option {
    padding: 16px;
  }

  .exam-option-name {
    font-size: 16px;
  }

  .exam-option-description {
    font-size: 13px;
    padding-left: 0;
    margin-top: 8px;
  }

  .exam-option-header {
    flex-direction: column;
  }

  .exam-option-radio {
    margin-bottom: 8px;
  }
}

  </style>

{%- comment -%} Exam Selector JavaScript {%- endcomment -%}
{%- if show_exam_selector -%}
  <script src="{{ 'exam-selector.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- comment -%} Exam Modal HTML {%- endcomment -%}
{%- if show_exam_selector -%}
<div class="exam-modal-overlay" id="exam-modal-{{ section_id }}">
  <div class="exam-modal">
    <button type="button" class="exam-modal-close" aria-label="Close">&times;</button>
    <h2 class="exam-modal-title">Select Your Exam Option</h2>

    <div class="exam-option selected" data-exam-value="NASM Certified Personal Trainer (NCCA Accredited Certification Exam)">
      <div class="exam-option-header">
        <div class="exam-option-radio"></div>
        <h3 class="exam-option-name">Exam Option 1: NASM Certified Personal Trainer (NCCA Accredited Certification Exam)</h3>
      </div>
      <p class="exam-option-description">
        The NCCA is a nationally recognized third-party agency that accredits certification programs which are able to meet and comply with its standards. This closed-book exam has 120 questions. You must pass with a scaled score of 70 or better. This proctored exam can be administered either in-person or online, and you will have 2 hours to complete the test. You must take this exam within 180 days of your enrollment date.
      </p>
    </div>

    <div class="exam-option" data-exam-value="NASM Personal Trainer Certificate (Non-Proctored Exam)">
      <div class="exam-option-header">
        <div class="exam-option-radio"></div>
        <h3 class="exam-option-name">Exam Option 2: NASM Personal Trainer Certificate (Non-Proctored Exam)</h3>
      </div>
      <p class="exam-option-description">
        This non-proctored and open-book exam has 100 questions and requires a passing grade of 70%. This exam is administered online only. You will have 3 hours to complete the exam, and you must take the exam within 180 days of your enrollment date.
      </p>
    </div>

    <div class="exam-modal-footer">
      <button type="button" class="exam-modal-btn exam-modal-cancel">Cancel</button>
      <button type="button" class="exam-modal-btn exam-modal-confirm">Confirm Selection</button>
    </div>
  </div>
</div>
{%- endif -%}
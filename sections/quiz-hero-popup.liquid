        <!-- Hidden Shopify contact form (emails store customer email) -->
        {% form 'contact', id: 'qhp-contact-form' %}
          <div data-qhp-submit-form style="display:none;">
            <input type="hidden" name="contact[name]" data-qhp-form-name>
            <input type="hidden" name="contact[email]" data-qhp-form-email>

          </div>

          {% assign promo_points = section.settings.results_promo_points | newline_to_br | split: '<br />' %}
          {% if section.settings.results_promo_title != blank or section.settings.results_promo_text != blank or section.settings.results_promo_points != blank %}
            <div class="qhp__promo">
              {% if section.settings.results_promo_title != blank %}

        <script>
          (function(){
            var root = document.getElementById('QuizHeroPopup-{{ section.id }}');
            if(!root) return;

            var leadEnabled = {{ section.settings.lead_enabled | json }};
            var sendEnabled = {{ section.settings.send_enabled | json }};
            var sendMode = {{ section.settings.send_mode | json }}; // "auto" or "button"
            var sendProvider = {{ section.settings.send_provider | json }}; // "shopify_contact" or "webhook"
            var sendToEmail = {{ section.settings.send_to_email | json }};
            var sendCcEmails = {{ section.settings.send_cc_emails | json }};
            var sendSubject = {{ section.settings.send_subject | json }};
            var sendWebhookUrl = {{ section.settings.send_webhook_url | json }};

            var msgLeadRequired = {{ section.settings.lead_required_msg | json }};
            var msgSendSuccess = {{ section.settings.send_success_text | json }};
            var msgSendError = {{ section.settings.send_error_text | json }};
            var nextQuestionLabel = {{ section.settings.next_question_label | json }};
            var seeResultsLabel = {{ section.settings.see_results_label | json }};

            var openBtns = root.querySelectorAll('[data-qhp-open]');
            var backdrop = root.querySelector('[data-qhp-backdrop]');
            var modal = root.querySelector('[data-qhp-modal]');
            var closeBtn = root.querySelector('[data-qhp-close]');

            var quizWrap = root.querySelector('[data-qhp-quiz]');
            var resultsWrap = root.querySelector('[data-qhp-results]');

            var qText = root.querySelector('[data-qhp-question]');
            var optionsWrap = root.querySelector('[data-qhp-options]');
            var feedback = root.querySelector('[data-qhp-feedback]');
            var feedbackTitle = root.querySelector('[data-qhp-feedback-title]');
            var feedbackText = root.querySelector('[data-qhp-feedback-text]');
            var nextBtn = root.querySelector('[data-qhp-next]');

            var progressText = root.querySelector('[data-qhp-progress-text]');
            var scoreText = root.querySelector('[data-qhp-score-text]');
            var bar = root.querySelector('[data-qhp-bar]');

            var resTitle = root.querySelector('[data-qhp-result-title]');
            var resScore = root.querySelector('[data-qhp-result-score]');
            var resPct = root.querySelector('[data-qhp-result-pct]');
            var resMsg = root.querySelector('[data-qhp-result-message]');
            var resCta = root.querySelector('[data-qhp-result-cta]');
            var resCorrectCount = root.querySelector('[data-qhp-correct-count]');
            var resIncorrectCount = root.querySelector('[data-qhp-incorrect-count]');
            var retakeBtn = root.querySelector('[data-qhp-retake]');

            // Lead UI
            var leadNameInput = root.querySelector('[data-qhp-lead-name]');
            var leadEmailInput = root.querySelector('[data-qhp-lead-email]');
            var leadStartBtn = root.querySelector('[data-qhp-start]');
            var leadError = root.querySelector('[data-qhp-lead-error]');

            // Submit UI
            var sendBtn = root.querySelector('[data-qhp-send]');
            var sendStatus = root.querySelector('[data-qhp-send-status]');
            var submitFormWrap = root.querySelector('[data-qhp-submit-form]');
            var submitForm = submitFormWrap ? submitFormWrap.closest('form') : null;
            var formName = root.querySelector('[data-qhp-form-name]');
            var formEmail = root.querySelector('[data-qhp-form-email]');
            var formSubject = root.querySelector('[data-qhp-form-subject]');
            var formBody = root.querySelector('[data-qhp-form-body]');

            var dataEl = root.querySelector('script[type="application/json"][data-qhp-questions]');
            var defaultDataEl = root.querySelector('script[type="application/json"][data-qhp-default-questions]');
            var raw = [];
            var defaultRaw = [];
            try { raw = JSON.parse(dataEl.textContent || '[]'); } catch(e){ raw = []; }
            try { defaultRaw = JSON.parse(defaultDataEl.textContent || '[]'); } catch(e){ defaultRaw = []; }

            function normalizeOptionsRaw(value){
              return (value || '')
                .split('\n')
                .map(function(s){ return (s || '').trim(); })
                .filter(Boolean)
                .join('\n');
            }

            function isPlaceholderQuestion(q){
              return (q.question || '').trim() === 'Your question here...' &&
                normalizeOptionsRaw(q.options_raw || '') === 'Option 1\nOption 2\nOption 3\nOption 4' &&
                (q.explanation || '').trim() === 'Explanation text...';
            }

            function normalizeQuestions(items){
              return (items || []).map(function(q){
                var opts = normalizeOptionsRaw(q.options_raw || '').split('\n').filter(Boolean);
                return {
                  question: q.question || '',
                  options: opts,
                  correct: Math.max(0, (parseInt(q.correct,10) || 1) - 1),
                  explanation: q.explanation || ''
                };
              }).filter(function(q){ return q.question && q.options.length >= 2; });
            }

            var customRaw = (raw || []).filter(function(q){ return !isPlaceholderQuestion(q); });
            var questions = customRaw.length ? normalizeQuestions(customRaw) : normalizeQuestions(defaultRaw);

            // State
            var started = false;
            var lead = { name: '', email: '' };

            var idx = 0;
            var selected = null;
            var showFeedback = false;
            var score = 0;

            var correctByQ = []; // boolean per question
            var sent = false;

            var closeResets = {{ section.settings.close_resets | json }};
            var redirectAfterQuiz = {{ section.settings.redirect_after_quiz | json }};
            var redirectUrl = {{ section.settings.redirect_url | json }};
            var redirectDelay = {{ section.settings.redirect_delay | json }} || 5;

            function lockScroll(locked){
              if(locked){
                root._qhpPrevOverflow = document.body.style.overflow;
                document.body.style.overflow = 'hidden';
              } else {
                document.body.style.overflow = root._qhpPrevOverflow || '';
              }
            }

            function openModal(){
              if(!questions.length) return;

              root.classList.add('qhp--open');
              backdrop.setAttribute('aria-hidden','false');
              modal.setAttribute('aria-hidden','false');
              lockScroll(true);

              resultsWrap.classList.remove('is-visible');
              resultsWrap.style.display = 'none';
              quizWrap.style.display = '';

              if(leadEnabled){
                root.classList.remove('qhp--started');
                started = false;
                if(leadError){ leadError.classList.remove('is-visible'); leadError.textContent=''; }
              } else {
                started = true;
                root.classList.add('qhp--started');
              }

              resetQuizStateOnly();
              setTimeout(function(){ closeBtn && closeBtn.focus(); }, 0);
            }

            function closeModal(){
              root.classList.remove('qhp--open');
              backdrop.setAttribute('aria-hidden','true');
              modal.setAttribute('aria-hidden','true');
              lockScroll(false);

              if(closeResets){
                resetAll();
              }
            }

            function resetQuizStateOnly(){
              idx = 0;
              selected = null;
              showFeedback = false;
              score = 0;
              correctByQ = [];
              sent = false;

              if(sendStatus) sendStatus.textContent = '';
              if(sendBtn) sendBtn.disabled = false;

              feedback.classList.remove('is-visible', 'qhp__feedback--correct');
              nextBtn.classList.remove('is-visible');

              render();
            }

            function resetAll(){
              lead = { name:'', email:'' };
              if(leadNameInput) leadNameInput.value = '';
              if(leadEmailInput) leadEmailInput.value = '';
              if(leadError){ leadError.classList.remove('is-visible'); leadError.textContent=''; }

              started = !leadEnabled;
              root.classList.toggle('qhp--started', started);

              resetQuizStateOnly();
            }

            function updateProgress(){
              var total = questions.length;
              progressText.textContent = 'Question ' + (idx + 1) + ' of ' + total;
              var answeredCount = idx + (showFeedback ? 1 : 0);
              scoreText.textContent = 'Score: ' + score + '/' + (answeredCount || 0);
              bar.style.width = ((idx + 1) / total * 100) + '%';
            }

            function clearOptions(){
              while(optionsWrap.firstChild) optionsWrap.removeChild(optionsWrap.firstChild);
            }

            function makeOptionBtn(label, optIndex){
              var btn = document.createElement('button');
              btn.type = 'button';
              btn.className = 'qhp__option';
              btn.setAttribute('data-opt', String(optIndex));

              var textSpan = document.createElement('span');
              textSpan.className = 'qhp__optionText';
              textSpan.textContent = label;

              var badge = document.createElement('span');
              badge.className = 'qhp__badge';
              badge.textContent = '';

              btn.appendChild(textSpan);
              btn.appendChild(badge);

              btn.addEventListener('click', function(){
                if(showFeedback) return;

                selected = optIndex;
                showFeedback = true;

                var isCorrect = selected === questions[idx].correct;
                correctByQ[idx] = isCorrect;

                if(isCorrect) score++;

                renderFeedback(isCorrect);
                renderOptionsState();
                nextBtn.textContent = idx < questions.length - 1 ? nextQuestionLabel : seeResultsLabel;
                nextBtn.classList.add('is-visible');
                updateProgress();
              });

              return btn;
            }

            function renderOptionsState(){
              var q = questions[idx];
              var buttons = optionsWrap.querySelectorAll('.qhp__option');

              buttons.forEach(function(b){
                b.disabled = true;
                var i = parseInt(b.getAttribute('data-opt'), 10);
                var badge = b.querySelector('.qhp__badge');

                b.classList.remove('qhp__option--correct','qhp__option--wrong');
                if(badge) badge.textContent = '';

                if(showFeedback){
                  if(i === q.correct){
                    b.classList.add('qhp__option--correct');
                    if(badge) badge.textContent = '✓';
                  } else if(i === selected){
                    b.classList.add('qhp__option--wrong');
                    if(badge) badge.textContent = '✕';
                  }
                }
              });
            }

            function renderFeedback(isCorrect){
              var q = questions[idx];

              feedbackTitle.textContent = isCorrect ? 'Correct! 🎉' : 'Not quite, but great try!';
              feedbackText.textContent = q.explanation || '';
              feedback.classList.remove('qhp__feedback--correct');
              if(isCorrect){
                feedback.classList.add('qhp__feedback--correct');
              }
              feedback.classList.add('is-visible');
            }

            function renderQuestion(){
              var q = questions[idx];
              qText.textContent = q.question;

              clearOptions();
              q.options.forEach(function(opt, i){
                optionsWrap.appendChild(makeOptionBtn(opt, i));
              });

              feedback.classList.remove('is-visible', 'qhp__feedback--correct');
              nextBtn.classList.remove('is-visible');
              nextBtn.textContent = nextQuestionLabel;
              showFeedback = false;
              selected = null;
              updateProgress();
            }

            function getResultBucket(pct){
              if(pct >= 90){
                return { title: {{ section.settings.tier1_title | json }}, message: {{ section.settings.tier1_message | json }}, cta: {{ section.settings.tier1_cta | json }} };
              }
              if(pct >= 75){
                return { title: {{ section.settings.tier2_title | json }}, message: {{ section.settings.tier2_message | json }}, cta: {{ section.settings.tier2_cta | json }} };
              }
              if(pct >= 60){
                return { title: {{ section.settings.tier3_title | json }}, message: {{ section.settings.tier3_message | json }}, cta: {{ section.settings.tier3_cta | json }} };
              }
              return { title: {{ section.settings.tier4_title | json }}, message: {{ section.settings.tier4_message | json }}, cta: {{ section.settings.tier4_cta | json }} };
            }

            function splitEmails(value){
              return String(value || '')
                .split(/[\n,;]/)
                .map(function(item){ return item.trim(); })
                .filter(Boolean);
            }

            function buildResultPayload(){
              var total = questions.length;
              var pct = total ? Math.round((score / total) * 100) : 0;
              var bucket = getResultBucket(pct);

              return {
                quiz_title: {{ section.settings.quiz_title | json }},
                page_url: window.location.href,
                sent_via: sendProvider,
                to: splitEmails(sendToEmail),
                cc: splitEmails(sendCcEmails),
                subject: sendSubject || 'Quiz Result Submission',
                participant: {
                  name: lead.name || '',
                  email: lead.email || ''
                },
                result: {
                  score: score,
                  total_questions: total,
                  percentage: pct,
                  tier_title: bucket.title || '',
                  tier_message: bucket.message || '',
                  tier_cta: bucket.cta || ''
                },
                breakdown_text: correctByQ.map(function(isCorrect, i){
                  return 'Q' + (i + 1) + ': ' + (isCorrect ? 'Correct' : 'Incorrect');
                }).join('\n'),
                answers: questions.map(function(question, i){
                  return {
                    index: i + 1,
                    question: question.question,
                    correct_option: question.options[question.correct] || '',
                    is_correct: !!correctByQ[i]
                  };
                })
              };
            }

            function buildResultBody(payload){
              return [
                payload.subject || 'Quiz Result Submission',
                '-----------------------',
                'Send To: ' + (payload.to && payload.to.length ? payload.to.join(', ') : 'Store contact email'),
                'CC: ' + (payload.cc && payload.cc.length ? payload.cc.join(', ') : 'None'),
                'Name: ' + (payload.participant.name || ''),
                'Email: ' + (payload.participant.email || ''),
                'Score: ' + payload.result.score + '/' + payload.result.total_questions + ' (' + payload.result.percentage + '%)',
                'Result Tier: ' + (payload.result.tier_title || ''),
                'Page URL: ' + payload.page_url,
                '',
                'Breakdown:',
                payload.breakdown_text || '',
                '',
                'Message:',
                payload.result.tier_message || '',
                '',
                'CTA:',
                payload.result.tier_cta || ''
              ].join('\n');
            }

            function showResults(){
              var total = questions.length;
              var pct = total ? Math.round((score / total) * 100) : 0;
              var bucket = getResultBucket(pct);

              resTitle.textContent = bucket.title || 'Your Results';
              resScore.textContent = score + '/' + total;
              resPct.textContent = pct + '% correct';

              resMsg.textContent = bucket.message || '';
              resCta.textContent = bucket.cta || '';
              if(resCorrectCount) resCorrectCount.textContent = score;
              if(resIncorrectCount) resIncorrectCount.textContent = Math.max(total - score, 0);

              quizWrap.style.display = 'none';
              resultsWrap.style.display = '';
              resultsWrap.classList.add('is-visible');

              if(sendEnabled && sendMode === 'auto' && !sent){
                submitResults();
              }

              if(redirectAfterQuiz && redirectUrl){
                setTimeout(function(){
                  window.location.href = redirectUrl;
                }, redirectDelay * 1000);
              }
            }

            function render(){
              if(!questions.length){
                qText.textContent = 'No quiz questions found. Please add question blocks.';
                clearOptions();
                return;
              }
              renderQuestion();
            }

            function onNext(){
              if(!showFeedback) return;

              if(idx < questions.length - 1){
                idx++;
                renderQuestion();
              } else {
                showResults();
              }
            }

            function validateLead(){
              var name = (leadNameInput && leadNameInput.value || '').trim();
              var email = (leadEmailInput && leadEmailInput.value || '').trim();

              var ok = name.length > 1 && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
              if(!ok){
                if(leadError){
                  leadError.textContent = msgLeadRequired || 'Please enter your name and a valid email to begin.';
                  leadError.classList.add('is-visible');
                }
                return null;
              }
              if(leadError){
                leadError.textContent = '';
                leadError.classList.remove('is-visible');
              }
              return { name: name, email: email };
            }

            function startQuiz(){
              if(!leadEnabled){
                started = true;
                root.classList.add('qhp--started');
                resetQuizStateOnly();
                return;
              }

              var v = validateLead();
              if(!v) return;

              lead = v;
              started = true;
              root.classList.add('qhp--started');
              resetQuizStateOnly();
            }

            async function submitResults(){
              if(!sendEnabled) return;
              if(sent) return;

              if(submitFormWrap){
                var hp = submitFormWrap.querySelector('input[name="contact[company]"]');
                if(hp && hp.value) return;
              }

              if(leadEnabled && (!lead.email || !lead.name)){
                var v = validateLead();
                if(!v) return;
                lead = v;
              }

              if(sendBtn) sendBtn.disabled = true;
              if(sendStatus) sendStatus.textContent = 'Sending results…';

              var payloadData = buildResultPayload();
              var body = buildResultBody(payloadData);

              try{
                if(sendProvider === 'webhook'){
                  if(!sendWebhookUrl){
                    throw new Error('Missing webhook URL');
                  }

                  var webhookResp = await fetch(sendWebhookUrl, {
                    method: 'POST',
                    headers: {
                      'Content-Type': 'application/json',
                      'Accept': 'application/json, text/plain, */*'
                    },
                    body: JSON.stringify(payloadData)
                  });

                  if(!webhookResp || !webhookResp.ok){
                    throw new Error('Webhook request failed');
                  }

                  sent = true;
                  if(sendStatus) sendStatus.textContent = msgSendSuccess || 'Sent! Our team received your quiz results.';
                  return;
                }

                if(!payloadData.participant.email){
                  throw new Error('Participant email is required for Shopify contact delivery');
                }

                if(formName) formName.value = lead.name || 'Quiz Participant';
                if(formEmail) formEmail.value = lead.email || '';
                if(formSubject) formSubject.value = payloadData.subject || 'Quiz Result Submission';
                if(formBody) formBody.value = body;

                var fd = new FormData(submitForm);
                var payload = new URLSearchParams();
                fd.forEach(function(v,k){ payload.append(k, v); });

                var resp = await fetch('/contact', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8' },
                  body: payload.toString()
                });

                if(resp && (resp.ok || resp.status === 200)){
                  sent = true;
                  if(sendStatus) sendStatus.textContent = msgSendSuccess || 'Sent! Our team received your quiz results.';
                } else {
                  throw new Error('Shopify contact request failed');
                }
              } catch(err){
                if(sendBtn) sendBtn.disabled = false;
                if(sendStatus) sendStatus.textContent = msgSendError || 'Sorry, we could not send your results. Please try again.';
              }
            }

            // Bindings
            openBtns.forEach(function(btn){ btn.addEventListener('click', function(e){ e.preventDefault(); openModal(); }); });
            closeBtn.addEventListener('click', closeModal);
            backdrop.addEventListener('click', closeModal);
            nextBtn.addEventListener('click', onNext);

            if(leadStartBtn) leadStartBtn.addEventListener('click', startQuiz);
            if(sendBtn) sendBtn.addEventListener('click', submitResults);

            retakeBtn && retakeBtn.addEventListener('click', function(){
              resetQuizStateOnly();
              quizWrap.style.display = '';
              resultsWrap.style.display = 'none';
              resultsWrap.classList.remove('is-visible');
            });

            document.addEventListener('keydown', function(e){
              if(!root.classList.contains('qhp--open')) return;
              if(e.key === 'Escape') closeModal();
            });

            // initial
            render();
          })();
        </script>
      </div>
    </div>
  </div>

  {%- comment -%} Calendly popup script {%- endcomment -%}
  <script>
  (function(){
    var sectionId = '{{ section.id }}';
    var modal = document.getElementById('qhp-calendly-modal-' + sectionId);
    var mount = document.getElementById('qhp-calendly-mount-' + sectionId);
    if (!modal || !mount) return;

    function openCalendly(url){
      mount.innerHTML = '';
      var iframe = document.createElement('iframe');
      iframe.src = url;
      iframe.title = 'Book a Call';
      iframe.loading = 'lazy';
      iframe.setAttribute('allow', 'payment');
      iframe.setAttribute('allowtransparency', 'true');
      iframe.setAttribute('frameborder', '0');
      mount.appendChild(iframe);

      modal.hidden = false;
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      /* Trigger animation after DOM update */
      requestAnimationFrame(function(){
        requestAnimationFrame(function(){
          modal.classList.add('is-open');
        });
      });
    }

    function closeCalendly(){
      modal.classList.remove('is-open');
      document.body.style.overflow = '';
      /* Wait for animation to finish before hiding */
      setTimeout(function(){
        modal.hidden = true;
        modal.setAttribute('aria-hidden', 'true');
        mount.innerHTML = '';
      }, 350);
    }

    document.addEventListener('click', function(e){
      var btn = e.target.closest('[data-qhp-calendly]');
      if (btn) {
        e.preventDefault();
        e.stopPropagation();
        var href = btn.getAttribute('href');
        if (href) openCalendly(href);
        return;
      }
      var closer = e.target.closest('[data-qhp-calendly-close]');
      if (closer && modal && !modal.hidden) {
        closeCalendly();
      }
    });

    document.addEventListener('keydown', function(e){
      if (e.key === 'Escape' && modal && !modal.hidden) closeCalendly();
    });

    /* Safari fix: ensure touch events work on iOS */
    if (modal) {
      modal.addEventListener('touchend', function(e){
        var closer = e.target.closest('[data-qhp-calendly-close]');
        if (closer) { e.preventDefault(); closeCalendly(); }
      }, { passive: false });
    }
  })();
  </script>
</section>


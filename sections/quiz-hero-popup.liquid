<section
  id="QuizHeroPopup-{{ section.id }}"
  class="qhp qhp--{{ section.id }}"
  data-qhp-root
  style="
    --qhp-bg: {{ section.settings.section_bg }};
    --qhp-heading: {{ section.settings.heading_color }};
    --qhp-text: {{ section.settings.text_color }};
    --qhp-primary-bg: {{ section.settings.primary_btn_bg }};
    --qhp-primary-text: {{ section.settings.primary_btn_text }};
    --qhp-secondary-bg: {{ section.settings.secondary_btn_bg }};
    --qhp-secondary-text: {{ section.settings.secondary_btn_text }};
    --qhp-modal-bg: {{ section.settings.modal_bg }};
    --qhp-accent: {{ section.settings.accent_color }};
    --qhp-correct: {{ section.settings.correct_color }};
    --qhp-wrong: {{ section.settings.wrong_color }};
  "
>
  <style>
    .qhp{
      background: var(--qhp-bg);
      color: var(--qhp-text);
      padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    }
    .qhp .qhp__container{
      max-width: {{ section.settings.max_width }}px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .qhp .qhp__grid{
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      align-items: center;
    }
    .qhp .qhp__grid--image-left .qhp__media{ order: -1; }
    .qhp .qhp__grid--image-left .qhp__content{ order: 1; }

    .qhp .qhp__content{ max-width: 560px; }

    .qhp .qhp__eyebrow{
      font-family: Arial, Helvetica, sans-serif;
      font-size: 14px;
      font-style: italic;
      letter-spacing: .02em;
      text-transform: none;
      opacity: .75;
      margin: 0 0 10px;
    }

    .qhp .qhp__heading{
      font-family: 'Anton', sans-serif;
      font-size: clamp(28px, 3.3vw, 44px);
      line-height: 1.05;
      margin: 0 0 14px;
      color: var(--qhp-heading);
      font-weight: 400;
      text-transform: uppercase;
    }

    .qhp .qhp__desc{
      font-family: Arial, Helvetica, sans-serif;
      font-size: 16px;
      line-height: 1.55;
      margin: 0 0 22px;
      max-width: 520px;
      opacity: .95;
    }

    .qhp .qhp__actions{
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
      margin: 0 0 10px;
    }
    .qhp .qhp__actions .btn {
      padding-left: 20px;
      padding-right: 20px;
    }

    .qhp .qhp__advisor{ margin: 0 0 14px; font-size: 15px; opacity: .95; }

    /* Calendly popup modal */
    .qhp-calendly-modal[hidden]{ display: none; }
    .qhp-calendly-modal{
      position: fixed;
      inset: 0;
      z-index: 99999;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 16px;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s ease;
    }
    .qhp-calendly-modal.is-open{
      opacity: 1;
      visibility: visible;
    }
    .qhp-calendly-modal__overlay{
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      -webkit-backdrop-filter: blur(6px);
      backdrop-filter: blur(6px);
    }
    .qhp-calendly-modal__dialog{
      position: relative;
      width: 100%;
      max-width: 700px;
      height: 85vh;
      max-height: 750px;
      background: #fff;
      border-radius: 16px;
      overflow: hidden;
      z-index: 2;
      box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(0, 0, 0, 0.06);
      transform: translateY(30px) scale(0.95);
      transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.35s ease;
      opacity: 0;
    }
    .qhp-calendly-modal.is-open .qhp-calendly-modal__dialog{
      transform: translateY(0) scale(1);
      opacity: 1;
    }
    .qhp-calendly-modal__close{
      position: absolute;
      top: 12px;
      right: 12px;
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid rgba(0, 0, 0, 0.1);
      border-radius: 50%;
      width: 40px;
      height: 40px;
      font-size: 22px;
      line-height: 1;
      cursor: pointer;
      z-index: 3;
      display: grid;
      place-items: center;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
      transition: background 0.15s ease, transform 0.15s ease;
    }
    .qhp-calendly-modal__close:hover{
      background: #fff;
      transform: scale(1.1);
    }
    .qhp-calendly-modal__mount{
      width: 100%;
      height: 100%;
    }
    .qhp-calendly-modal__mount iframe{
      width: 100%;
      height: 100%;
      border: 0;
      display: block;
    }
    @media (max-width: 640px){
      .qhp-calendly-modal{ padding: 10px; }
      .qhp-calendly-modal__dialog{
        max-width: 100%;
        height: 92vh;
        max-height: none;
        border-radius: 12px;
      }
    }

    .qhp .qhp__media{
      border-radius: 0;
      overflow: hidden;
      background: rgba(0,0,0,.04);
      min-height: 260px;
    }
    .qhp .qhp__media img{
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
    }

    @media (max-width: 900px){
      .qhp .qhp__grid{ grid-template-columns: 1fr; }
      .qhp .qhp__content{ max-width: 100%; }
      .qhp .qhp__media{
        min-height: auto;
        max-height: 400px;
      }
      .qhp .qhp__media img{
        height: auto;
        max-height: 400px;
      }
    }

    /* Modal */
    .qhp .qhp__backdrop{
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      -webkit-backdrop-filter: blur(6px);
      backdrop-filter: blur(6px);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s ease;
      z-index: 9998;
    }
    .qhp .qhp__modal{
      position: fixed;
      inset: 0;
      display: grid;
      place-items: center;
      padding: 18px;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s ease;
      z-index: 9999;
    }
    .qhp.qhp--open .qhp__backdrop,
    .qhp.qhp--open .qhp__modal{
      opacity: 1;
      visibility: visible;
    }

    .qhp .qhp__dialog{
      width: min(700px, 100%);
      max-height: 90vh;
      overflow: auto;
      background: var(--qhp-modal-bg);
      border-radius: 16px;
      box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(0, 0, 0, 0.06);
      transform: translateY(30px) scale(0.95);
      transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.35s ease;
      opacity: 0;
    }
    .qhp.qhp--open .qhp__dialog{
      transform: translateY(0) scale(1);
      opacity: 1;
    }

    .qhp .qhp__dialogHeader{
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 18px;
      border-bottom: 1px solid rgba(0,0,0,.08);
      position: sticky;
      top: 0;
      background: var(--qhp-modal-bg);
      z-index: 2;
    }

    .qhp .qhp__dialogTitle{
      margin: 0;
      font-size: 16px;
      font-weight: 900;
      letter-spacing: .02em;
      color: var(--qhp-heading);
      display: none;
    }
    .qhp .qhp__dialogClose{
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1px solid rgba(0,0,0,.1);
      background: rgba(255,255,255,.9);
      cursor: pointer;
      display: grid;
      place-items: center;
      box-shadow: 0 2px 8px rgba(0,0,0,.12);
      transition: background 0.15s ease, transform 0.15s ease;
    }
    .qhp .qhp__dialogClose:hover{
      background: #fff;
      transform: scale(1.1);
    }

    .qhp .qhp__dialogBody{ padding: 18px; }

    /* Lead gate + Send status */
    .qhp [data-qhp-quiz-ui]{ display:none; }
    .qhp.qhp--started [data-qhp-quiz-ui]{ display:block; }
    .qhp.qhp--started [data-qhp-lead]{ display:none; }

    .qhp .qhp__leadCard{
      background:#fff;
      border:1px solid rgba(0,0,0,.08);
      border-radius:16px;
      padding:16px;
      margin-bottom:14px;
    }
    .qhp .qhp__leadTitle{
      margin:0 0 6px;
      font-size:18px;
      font-weight:1000;
      color:var(--qhp-heading);
    }
    .qhp .qhp__leadDesc{ margin:0 0 12px; opacity:.9; }

    .qhp .qhp__fieldGrid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
      margin-bottom: 12px;
    }
    @media(max-width:720px){
      .qhp .qhp__fieldGrid{ grid-template-columns:1fr; }
    }
    .qhp .qhp__label{
      display:block;
      font-size:12px;
      font-weight:900;
      letter-spacing:.02em;
      margin-bottom:6px;
      color:var(--qhp-heading);
    }
    .qhp .qhp__input{
      width:100%;
      border-radius:12px;
      border:1px solid rgba(0,0,0,.14);
      padding:12px 12px;
      font-weight:700;
      outline:none;
    }
    .qhp .qhp__input:focus{
      border-color:var(--qhp-accent);
      box-shadow:0 0 0 3px rgba(15,130,140,.18);
    }
    .qhp .qhp__leadError{
      margin:10px 0 0;
      color:#b42318;
      font-weight:800;
      display:none;
    }
    .qhp .qhp__leadError.is-visible{ display:block; }

    .qhp .qhp__sendStatus{
      margin:10px 0 0;
      font-weight:800;
      opacity:.95;
    }
    .qhp .qhp__hp{
      position:absolute!important;
      left:-9999px!important;
      top:auto!important;
      width:1px!important;
      height:1px!important;
      overflow:hidden!important;
    }

    /* Quiz UI */
    .qhp .qhp__quizHeader{
      background: rgba(0,0,0,.03);
      border: 1px solid rgba(0,0,0,.08);
      border-radius: 16px;
      padding: 16px;
      margin-bottom: 14px;
    }
    .qhp .qhp__quizH1{
      margin: 0 0 6px;
      font-size: 22px;
      color: var(--qhp-heading);
      font-weight: 900;
    }
    .qhp .qhp__quizSub{ margin: 0; font-size: 14px; opacity: .9; }

    .qhp .qhp__progressCard{
      background: #fff;
      border: 1px solid rgba(0,0,0,.08);
      border-radius: 16px;
      padding: 14px;
      margin-bottom: 14px;
    }
    .qhp .qhp__progressRow{
      display:flex;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 8px;
      font-size: 13px;
      font-weight: 800;
      color: var(--qhp-heading);
    }
    .qhp .qhp__bar{
      width: 100%;
      height: 12px;
      border-radius: 999px;
      background: rgba(0,0,0,.08);
      overflow: hidden;
      position: relative;
    }
    .qhp .qhp__barFill{
      height: 100%;
      width: 0%;
      background: var(--qhp-accent);
      border-radius: 999px;
      transition: width .4s ease;
      position: relative;
    }
    .qhp .qhp__barFill::after{
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: 30%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.3));
      border-radius: 999px;
    }

    .qhp .qhp__questionCard{
      background: #fff;
      border: 1px solid rgba(0,0,0,.08);
      border-radius: 16px;
      padding: 16px;
    }
    .qhp .qhp__qTitle{
      margin: 0 0 14px;
      font-size: 18px;
      font-weight: 900;
      color: var(--qhp-heading);
    }

    .qhp .qhp__options{
      display: grid;
      gap: 10px;
      margin: 0 0 14px;
    }
    .qhp .qhp__option{
      width: 100%;
      text-align: left;
      border-radius: 14px;
      border: 2px solid rgba(0,0,0,.10);
      padding: 12px 14px;
      background: #fff;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: border-color .12s ease, background .12s ease, transform .12s ease;
      font-weight: 700;
      color: #0d2b28;
    }
    .qhp .qhp__option:hover{ border-color: var(--qhp-accent); background: rgba(0,0,0,.02); }
    .qhp .qhp__option[disabled]{ cursor: not-allowed; opacity: .95; }

    .qhp .qhp__optionText{
      flex: 1;
    }

    .qhp .qhp__option--correct{
      border-color: var(--qhp-correct);
      background: rgba(0,0,0,.02);
      background: color-mix(in srgb, var(--qhp-correct) 15%, #fff);
    }
    .qhp .qhp__option--wrong{
      border-color: var(--qhp-wrong);
      background: rgba(0,0,0,.02);
      background: color-mix(in srgb, var(--qhp-wrong) 12%, #fff);
    }

    .qhp .qhp__badge{
      display: inline-flex;
      width: 26px;
      height: 26px;
      border-radius: 999px;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 900;
      border: 1px solid rgba(0,0,0,.12);
      background: rgba(0,0,0,.03);
      flex: 0 0 auto;
    }

    .qhp .qhp__feedback{
      border-radius: 14px;
      padding: 14px;
      border: 2px solid rgba(0,0,0,.10);
      background: rgba(0,0,0,.02);
      display: none;
      margin-bottom: 12px;
    }
    .qhp .qhp__feedback.is-visible{ display:block; }
    .qhp .qhp__feedback--correct{
      border-color: var(--qhp-correct);
      background: color-mix(in srgb, var(--qhp-correct) 15%, #fff);
    }
    .qhp .qhp__feedbackTitle{
      margin: 0 0 6px;
      font-weight: 900;
      color: var(--qhp-heading);
    }
    .qhp .qhp__feedbackText{ margin: 0; line-height: 1.5; }

    .qhp .qhp__next{
      max-width: 200px;
      border-radius: 14px;
      padding: 14px 16px;
      background: var(--qhp-heading);
      color: #fff;
      border: 0;
      font-weight: 900;
      cursor: pointer;
      display: none;
    }
    .qhp .qhp__next.is-visible{ display:block; }
    .qhp .qhp__next:hover{ opacity: .92; }

    .qhp .qhp__powered{
      text-align:center;
      margin-top: 12px;
      font-size: 12px;
      opacity: .8;
    }

    /* Results */
    .qhp .qhp__results{ display:none; }
    .qhp .qhp__results.is-visible{ display:block; }

    .qhp .qhp__resultTop{
      text-align:center;
      padding: 10px 0 6px;
    }
    .qhp .qhp__trophy{
      width: 74px;
      height: 74px;
      border-radius: 999px;
      margin: 0 auto 10px;
      display:grid;
      place-items:center;
      background: linear-gradient(135deg, var(--qhp-accent), rgba(0,0,0,.25));
      color: #fff;
      font-size: 34px;
      font-weight: 900;
    }
    .qhp .qhp__resultTitle{
      margin: 0 0 8px;
      font-size: 22px;
      font-weight: 1000;
      color: var(--qhp-heading);
    }
    .qhp .qhp__resultScore{
      font-size: 46px;
      font-weight: 1000;
      color: var(--qhp-accent);
      margin: 0 0 4px;
    }
    .qhp .qhp__resultPct{
      margin: 0;
      opacity: .9;
      font-weight: 800;
    }
    .qhp .qhp__resultMsg{
      background: rgba(0,0,0,.03);
      border: 1px solid rgba(0,0,0,.08);
      border-radius: 16px;
      padding: 14px;
      margin: 14px 0;
      line-height: 1.6;
    }
    .qhp .qhp__resultBtns{
      display:grid;
      gap: 10px;
    }
    .qhp .qhp__linkBtn{
      width: 100%;
      border-radius: 14px;
      padding: 14px 16px;
      text-decoration: none;
      text-align:center;
      font-weight: 1000;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height: 46px;
      border: 0;
      cursor: pointer;
    }
    .qhp .qhp__linkBtn--cta{ background: var(--qhp-accent); color: #fff; }
    .qhp .qhp__linkBtn--retake{ background: rgba(0,0,0,.08); color: #111; }
    .qhp .qhp__linkBtn[disabled]{ opacity:.6; cursor:not-allowed; }

    .qhp .qhp__resultBreakdown{
      background: #fff;
      border: 1px solid rgba(0,0,0,.08);
      border-radius: 16px;
      padding: 14px;
      margin: 14px 0;
    }
    .qhp .qhp__resultBreakdownTitle{
      margin: 0 0 12px;
      font-size: 16px;
      font-weight: 900;
      color: var(--qhp-heading);
    }
    .qhp .qhp__resultGrid{
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .qhp .qhp__resultStat{
      text-align: center;
      border-radius: 14px;
      padding: 16px 12px;
      border: 1px solid rgba(0,0,0,.08);
    }
    .qhp .qhp__resultStat--correct{
      background: color-mix(in srgb, var(--qhp-correct) 14%, #fff);
    }
    .qhp .qhp__resultStat--learn{
      background: color-mix(in srgb, var(--qhp-wrong) 10%, #fff);
    }
    .qhp .qhp__resultStatValue{
      font-size: 32px;
      font-weight: 1000;
      color: var(--qhp-heading);
      line-height: 1;
      margin-bottom: 6px;
    }
    .qhp .qhp__resultStatLabel{
      font-size: 13px;
      font-weight: 800;
      opacity: .9;
    }
    .qhp .qhp__promo{
      background: linear-gradient(135deg, var(--qhp-heading), var(--qhp-accent));
      color: #fff;
      border-radius: 16px;
      padding: 18px;
      margin: 14px 0;
    }
    .qhp .qhp__promoTitle{
      margin: 0 0 8px;
      font-size: 20px;
      font-weight: 1000;
    }
    .qhp .qhp__promoText{
      margin: 0 0 14px;
      font-size: 15px;
      line-height: 1.65;
      color: #fff;
      font-weight: 600;
    }
    .qhp .qhp__promoList{
      margin: 0;
      padding-left: 18px;
      color: #fff;
    }
    .qhp .qhp__promoList li{
      margin: 0 0 8px;
      line-height: 1.55;
      font-weight: 700;
      font-size: 15px;
    }
    @media (max-width: 640px){
      .qhp .qhp__resultGrid{ grid-template-columns: 1fr; }
      .qhp .qhp__dialog{ width: 100%; }
    }
  </style>

  <div class="qhp__container">
    <div class="qhp__grid{% if section.settings.image_position == 'left' %} qhp__grid--image-left{% endif %}">
      <div class="qhp__content">
        {% if section.settings.eyebrow != blank %}
          <p class="qhp__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="qhp__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="qhp__desc">{{ section.settings.description }}</div>
        {% endif %}

        <div class="qhp__actions">
          {%- comment -%} PRIMARY BUTTON {%- endcomment -%}
          {%- assign pri_mode = section.settings.primary_btn_mode | default: 'quiz' -%}
          {%- if pri_mode == 'quiz' -%}
            <a href="#"
              class="btn button-b"
              style="background-color: {{ section.settings.primary_btn_bg }};"
              data-qhp-open
            >
              <span class="btn-label-down" style="color: {{ section.settings.primary_btn_text }};">{{ section.settings.primary_btn_label }}</span>
              <span class="btn-label-down" style="color: {{ section.settings.primary_btn_text }};">{{ section.settings.primary_btn_label }}</span>
            </a>
          {%- elsif pri_mode == 'typeform' and section.settings.primary_btn_typeform_url != blank -%}
            <a href="{{ section.settings.primary_btn_typeform_url }}"
              class="btn button-b"
              style="background-color: {{ section.settings.primary_btn_bg }};"
              {% if section.settings.primary_btn_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
            >
              <span class="btn-label-down" style="color: {{ section.settings.primary_btn_text }};">{{ section.settings.primary_btn_label }}</span>
              <span class="btn-label-down" style="color: {{ section.settings.primary_btn_text }};">{{ section.settings.primary_btn_label }}</span>
            </a>
          {%- elsif pri_mode == 'url' and section.settings.primary_btn_url != blank -%}
            <a href="{{ section.settings.primary_btn_url }}"
              class="btn button-b"
              style="background-color: {{ section.settings.primary_btn_bg }};"
              {% if section.settings.primary_btn_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
            >
              <span class="btn-label-down" style="color: {{ section.settings.primary_btn_text }};">{{ section.settings.primary_btn_label }}</span>
              <span class="btn-label-down" style="color: {{ section.settings.primary_btn_text }};">{{ section.settings.primary_btn_label }}</span>
            </a>
          {%- endif -%}

          {% if section.settings.advisor_text != blank %}
            <div class="qhp__advisor">{{ section.settings.advisor_text }}</div>
          {% endif %}

          {%- comment -%} SECONDARY BUTTON {%- endcomment -%}
          {%- assign sec_mode = section.settings.secondary_btn_mode | default: 'url' -%}
          {%- if section.settings.secondary_btn_label != blank -%}
            {%- if sec_mode == 'calendly' and section.settings.secondary_calendly_url != blank -%}
              {%- if section.settings.secondary_btn_new_tab -%}
                <a class="btn button-outline-hp"
                  href="{{ section.settings.secondary_calendly_url }}"
                  target="_blank"
                  rel="noopener noreferrer"
                  style="border: 2px solid {{ section.settings.secondary_btn_text }};">
                  <span class="btn-label-down" style="color: {{ section.settings.secondary_btn_text }};">{{ section.settings.secondary_btn_label }}</span>
                  <span class="btn-label-down" style="color: {{ section.settings.secondary_btn_text }};">{{ section.settings.secondary_btn_label }}</span>
                </a>
              {%- else -%}
                <a class="btn button-outline-hp"
                  href="{{ section.settings.secondary_calendly_url }}"
                  data-qhp-calendly
                  style="border: 2px solid {{ section.settings.secondary_btn_text }};">
                  <span class="btn-label-down" style="color: {{ section.settings.secondary_btn_text }};">{{ section.settings.secondary_btn_label }}</span>
                  <span class="btn-label-down" style="color: {{ section.settings.secondary_btn_text }};">{{ section.settings.secondary_btn_label }}</span>
                </a>
              {%- endif -%}
            {%- elsif sec_mode == 'url' and section.settings.secondary_btn_url != blank -%}
              <a class="btn button-outline-hp"
                href="{{ section.settings.secondary_btn_url }}"
                {% if section.settings.secondary_btn_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                style="border: 2px solid {{ section.settings.secondary_btn_text }};">
                <span class="btn-label-down" style="color: {{ section.settings.secondary_btn_text }};">{{ section.settings.secondary_btn_label }}</span>
                <span class="btn-label-down" style="color: {{ section.settings.secondary_btn_text }};">{{ section.settings.secondary_btn_label }}</span>
              </a>
            {%- endif -%}
          {%- endif -%}
        </div>

        {%- comment -%} Calendly popup modal {%- endcomment -%}
        <div id="qhp-calendly-modal-{{ section.id }}" class="qhp-calendly-modal" hidden aria-hidden="true">
          <div class="qhp-calendly-modal__overlay" data-qhp-calendly-close></div>
          <div class="qhp-calendly-modal__dialog">
            <button class="qhp-calendly-modal__close" type="button" data-qhp-calendly-close aria-label="Close">&times;</button>
            <div class="qhp-calendly-modal__mount" id="qhp-calendly-mount-{{ section.id }}"></div>
          </div>
        </div>
      </div>

      <div class="qhp__media">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 1600
            | image_tag:
              loading: 'lazy',
              widths: '480, 720, 960, 1200, 1600',
              sizes: '(min-width: 900px) 50vw, 100vw',
              alt: section.settings.image.alt | escape
          }}
        {% else %}
          <div style="padding: 26px; opacity: .7;">
            Upload an image in section settings.
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <!-- Backdrop + Modal -->
  <div class="qhp__backdrop" data-qhp-backdrop aria-hidden="true"></div>

  <div class="qhp__modal" data-qhp-modal aria-hidden="true">
    <div class="qhp__dialog" role="dialog" aria-modal="true" aria-label="Quiz">

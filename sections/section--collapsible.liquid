<section class="section--collapsible   {{ section.settings.section_class }}" style="padding-top: {{ section.settings.top_padding }}px; padding-bottom: {{ section.settings.bottom_padding }}px; background-color: {{ section.settings.background_color }};" id="{{ section.settings.section_id }}" >
  <div class="accordion--container" style="max-width: {{ section.settings.container_width }}px;">
    <div class="row">
      <div class="col-md-12">
        {%- if section.settings.title != blank -%}
 <div class="section--title-block ">
  <h2 class="is--flex-start" style="text-align: {{ section.settings.title_alignment }};">{{ section.settings.title }}</h2> 
</div>

          
        {%- endif -%}
        <div class="accordion--main theme--text-color">
          <div class="accordion--inner">
            {% for block in section.blocks %}
              {% if block.type == 'collapsible_row' %}
                <div class="accordion--item" data-wow-duration="2.5s">
                  <div class="accordion--title">
                    {%- if block.settings.heading != blank -%}
                      <h3>{{ block.settings.heading }}</h3>
                    {%- endif -%}
                    <div class="accordion--toggle">
                      <div class="toggle--icon toggle--close">
                            <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
<path d="M14.5625 18.3125C14.6875 18.4375 14.8333 18.5 15 18.5C15.1667 18.5 15.3125 18.4375 15.4375 18.3125L18.9375 14.8125C19.1458 14.6042 19.1979 14.375 19.0938 14.125C18.9896 13.875 18.7917 13.75 18.5 13.75H11.5C11.2083 13.75 11.0104 13.875 10.9063 14.125C10.8021 14.375 10.8542 14.6042 11.0625 14.8125L14.5625 18.3125ZM15 27.5C13.2708 27.5 11.6458 27.1717 10.125 26.515C8.60417 25.8583 7.28125 24.9679 6.15625 23.8438C5.03125 22.7196 4.14084 21.3967 3.485 19.875C2.82917 18.3533 2.50083 16.7283 2.5 15C2.49917 13.2717 2.8275 11.6467 3.485 10.125C4.1425 8.60333 5.03292 7.28042 6.15625 6.15625C7.27958 5.03208 8.6025 4.14167 10.125 3.485C11.6475 2.82833 13.2725 2.5 15 2.5C16.7275 2.5 18.3525 2.82833 19.875 3.485C21.3975 4.14167 22.7204 5.03208 23.8438 6.15625C24.9671 7.28042 25.8579 8.60333 26.5163 10.125C27.1746 11.6467 27.5025 13.2717 27.5 15C27.4975 16.7283 27.1692 18.3533 26.515 19.875C25.8608 21.3967 24.9704 22.7196 23.8438 23.8438C22.7171 24.9679 21.3942 25.8587 19.875 26.5162C18.3558 27.1737 16.7308 27.5017 15 27.5Z" fill="#0F828C"/>
</svg>
                      </div>
                      <div class="toggle--icon toggle--open">
<svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none">
<path d="M11.6875 15.4375C11.5625 15.3125 11.5 15.1667 11.5 15C11.5 14.8333 11.5625 14.6875 11.6875 14.5625L15.1875 11.0625C15.3958 10.8542 15.625 10.8021 15.875 10.9063C16.125 11.0104 16.25 11.2083 16.25 11.5L16.25 18.5C16.25 18.7917 16.125 18.9896 15.875 19.0937C15.625 19.1979 15.3958 19.1458 15.1875 18.9375L11.6875 15.4375ZM2.5 15C2.5 16.7292 2.82833 18.3542 3.485 19.875C4.14167 21.3958 5.03208 22.7187 6.15625 23.8437C7.28042 24.9687 8.60333 25.8592 10.125 26.515C11.6467 27.1708 13.2717 27.4992 15 27.5C16.7283 27.5008 18.3533 27.1725 19.875 26.515C21.3967 25.8575 22.7196 24.9671 23.8437 23.8437C24.9679 22.7204 25.8583 21.3975 26.515 19.875C27.1717 18.3525 27.5 16.7275 27.5 15C27.5 13.2725 27.1717 11.6475 26.515 10.125C25.8583 8.6025 24.9679 7.27958 23.8437 6.15625C22.7196 5.03291 21.3967 4.14208 19.875 3.48375C18.3533 2.82541 16.7283 2.4975 15 2.5C13.2717 2.5025 11.6467 2.83083 10.125 3.485C8.60333 4.13916 7.28042 5.02958 6.15625 6.15625C5.03208 7.28291 4.14125 8.60583 3.48375 10.125C2.82625 11.6442 2.49833 13.2692 2.5 15Z" fill="#0F828C"/>
</svg>

                
               
                      </div>
                    </div>
                  </div>
                  {%- if block.settings.row_content != blank -%}
                    <div class="accordion--content">
                      {{ block.settings.row_content }}
                    </div>
                  {%- endif -%}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
        {%- if section.settings.accordion_link != blank -%}
        <div class="link--line wow animate__animated animate__fadeIn" data-wow-duration="2.5s">
          <a href="{{ section.settings.accordion_link }}">{{ section.settings.accordion_link_title }}</a>
        </div>
        {%- endif -%}
      </div>
      {%- if section.settings.button_link != blank -%}
      <div class="accordion-footer-wrap">
        <p class="footer-text"> {{ section.settings.footer_text }}</p>
        <a href="{{ section.settings.button_link }}" {% if section.settings.button_text != "Contact Us" %} target="_blank" {% endif %} 
     class="btn button-yg">
            <span class="btn-label-down">{{ section.settings.button_text }}</span>
            <span class="btn-label-down">{{ section.settings.button_text }}</span>
        </a>
      </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Accordion Collapsible",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
                 {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "default": "certified-trainers"
    },
       {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "section_class",
      "label": "Section Class"
    },
    
    {
      "type": "text",
      "id": "title",
      "label": "Collapsible content",
      "default": "Accordion Title"
    },
     {
      "type": "select",
      "id": "title_alignment",
      "label": "Title Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "accordion_link_title",
      "label": "Link Title"
    },
    {
      "type": "url",
      "id": "accordion_link",
      "label": "Link"
    },
    {
      "type": "range",
      "id": "top_padding",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 92
    },
    {
      "type": "range",
      "id": "bottom_padding",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 92
    },
   {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 200,
      "max": 2000,
      "step": 20,
      "unit": "px",
      "default": 980
    },
     {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "Don’t see the answer to your question?"
    },
     {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "JOIN TODAY"
    },
        
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "default": "/"
    },
  ],
  "blocks": [
    {
      "type": "collapsible_row",
      "name": "Accordion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "COLLAPSIBLE ROW",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "row_content",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Accordion Collapsible",
      "blocks": [
        {
          "type": "collapsible_row"
        },
        {
          "type": "collapsible_row"
        },
        {
          "type": "collapsible_row"
        },
        {
          "type": "collapsible_row"
        }
      ]
    }
  ]
}
{% endschema %}
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
  $(document).ready(function(){

       if($('.accordion--main').length) {

        $('.accordion--main').each(function(){

            var $this = $(this);
            var itemBlock = $this.find('.accordion--item');
            var titleToggle = $this.find('.accordion--item .accordion--title');

            titleToggle.on('click', function(){

                var $this__ = $(this);
                var content = $this__.next();
                $this.find('.accordion--content').slideUp();
                itemBlock.removeClass('active');

                if(content.is(':visible')) {
                    content.slideUp();
                }
                else {
                    content.slideDown();
                    $this__.parent().addClass('active');
                }
            });

        });
    }

  });
</script>
{%- assign sid = section.id -%}
{{ 'hp-sections.css' | asset_url | stylesheet_tag }}

<section id="hp-elite-{{ sid }}" class="hp-elite">
  <div class="hp-elite__inner" style="max-width: {{ section.settings.container_width }}px;">
    <h2 class="hp-elite__title" style="font-size: {{ section.settings.title_size }}; color: {{ section.settings.title_color }};">{{ section.settings.heading }}</h2>
    <p class="hp-elite__subtitle" style="font-size: {{ section.settings.subtitle_size }}; color: {{ section.settings.subtitle_color }};">{{ section.settings.subtitle }}</p>

    <div class="hp-elite__grid{% if section.settings.image_position == 'right' %} hp-elite__grid--image-right{% endif %}">
      <div class="hp-elite__image">
        {%- if section.settings.product_image != blank -%}
          <img
            src="{{ section.settings.product_image | image_url: width: 800 }}"
            srcset="{{ section.settings.product_image | image_url: width: 500 }} 500w,
                    {{ section.settings.product_image | image_url: width: 800 }} 800w"
            sizes="(max-width: 749px) 90vw, 400px"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="400"
            height="475">
        {%- endif -%}
      </div>

      <div class="hp-elite__details">
        <h3 class="hp-elite__details-title" style="font-size: {{ section.settings.details_title_size }}; color: {{ section.settings.title_color }};">{{ section.settings.details_heading }}</h3>
        <ul class="hp-elite__checklist">
          {%- for block in section.blocks -%}
            {%- if block.type == 'checklist_item' -%}
              <li class="hp-elite__check-item" style="font-size: {{ section.settings.checklist_size }}; color: {{ section.settings.body_color }};" {{ block.shopify_attributes }}>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="12" fill="#0f828c"/>
                  <path d="M7 12.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>

        {%- if section.settings.bonus_text != blank -%}
          <div class="hp-elite__bonus" style="background-color: {{ section.settings.bonus_bg_color }}; color: {{ section.settings.bonus_text_color }}; font-size: {{ section.settings.bonus_font_size }};">
            {{ section.settings.bonus_text }}
          </div>
        {%- endif -%}

        <div class="hp-elite__pricing">
          <span class="hp-elite__sale-label" style="font-size: {{ section.settings.price_label_size }};">SALE PRICE:</span>
          <span class="hp-elite__sale-price" style="font-size: {{ section.settings.price_size }};">{{ section.settings.sale_price }}</span>
          <span class="hp-elite__reg-price" style="font-size: {{ section.settings.price_label_size }};">{{ section.settings.regular_price }}</span>
        </div>

        <div class="hp-elite__actions">
          {%- if section.settings.cart_link != blank -%}
            <a href="{{ section.settings.cart_link }}" class="btn button-yg" style="font-size: {{ section.settings.btn1_font_size }}; background-color: {{ section.settings.btn1_bg_color }};">
              <span class="btn-label-down" style="color: {{ section.settings.btn1_text_color }};">{{ section.settings.btn1_text }}</span>
              <span class="btn-label-down" style="color: {{ section.settings.btn1_text_color }};">{{ section.settings.btn1_text }}</span>
            </a>
          {%- endif -%}
          {%- if section.settings.lnpl_link != blank -%}
            <a href="{{ section.settings.lnpl_link }}" class="btn button-outline-hp" style="font-size: {{ section.settings.btn2_font_size }}; background-color: {{ section.settings.btn2_bg_color }}; border: 2px solid {{ section.settings.btn2_border_color }};">
              <span class="btn-label-down" style="color: {{ section.settings.btn2_text_color }};">{{ section.settings.btn2_text }}</span>
              <span class="btn-label-down" style="color: {{ section.settings.btn2_text_color }};">{{ section.settings.btn2_text }}</span>
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HP Elite Bundle",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Elite Bundle" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "NASM certified. NPTA™ trained. Career ready." },
    { "type": "image_picker", "id": "product_image", "label": "Product Image" },
    { "type": "text", "id": "details_heading", "label": "Details Heading", "default": "What's included" },
    { "type": "text", "id": "bonus_text", "label": "Bonus Text", "default": "FREE GLP-1 CERTIFICATION - Understanding Weight Loss Medications" },
    { "type": "text", "id": "sale_price", "label": "Sale Price", "default": "$2,497" },
    { "type": "text", "id": "regular_price", "label": "Regular Price", "default": "$4,899" },

    { "type": "header", "content": "Button 1 (Primary)" },
    { "type": "text", "id": "btn1_text", "label": "Button 1 Text", "default": "ADD TO CART" },
    { "type": "url", "id": "cart_link", "label": "Button 1 Link" },
    { "type": "text", "id": "btn1_font_size", "label": "Button 1 Font Size", "default": "14px" },
    { "type": "color", "id": "btn1_text_color", "label": "Button 1 Text Color", "default": "#141414" },
    { "type": "color", "id": "btn1_bg_color", "label": "Button 1 Background Color", "default": "#C1FF72" },

    { "type": "header", "content": "Button 2 (Secondary)" },
    { "type": "text", "id": "btn2_text", "label": "Button 2 Text", "default": "LEARN NOW, PAY LATER" },
    { "type": "url", "id": "lnpl_link", "label": "Button 2 Link" },
    { "type": "text", "id": "btn2_font_size", "label": "Button 2 Font Size", "default": "14px" },
    { "type": "color", "id": "btn2_text_color", "label": "Button 2 Text Color", "default": "#141414" },
    { "type": "color", "id": "btn2_bg_color", "label": "Button 2 Background Color", "default": "#ffffff" },
    { "type": "color", "id": "btn2_border_color", "label": "Button 2 Border Color", "default": "#141414" },

    { "type": "header", "content": "Typography" },
    { "type": "text", "id": "title_size", "label": "Title Font Size", "default": "clamp(28px, 4vw, 48px)" },
    { "type": "color", "id": "title_color", "label": "Title Color", "default": "#141414" },
    { "type": "text", "id": "subtitle_size", "label": "Subtitle Font Size", "default": "clamp(14px, 1.5vw, 18px)" },
    { "type": "color", "id": "subtitle_color", "label": "Subtitle Color", "default": "#555555" },
    { "type": "text", "id": "details_title_size", "label": "Details Title Font Size", "default": "clamp(20px, 2.5vw, 30px)" },
    { "type": "text", "id": "checklist_size", "label": "Checklist Font Size", "default": "clamp(14px, 1.3vw, 16px)" },
    { "type": "color", "id": "body_color", "label": "Body/Checklist Color", "default": "#141414" },
    { "type": "text", "id": "bonus_font_size", "label": "Bonus Font Size", "default": "clamp(13px, 1.2vw, 15px)" },
    { "type": "color", "id": "bonus_bg_color", "label": "Bonus Background Color", "default": "#e8e6e0" },
    { "type": "color", "id": "bonus_text_color", "label": "Bonus Text Color", "default": "#141414" },
    { "type": "text", "id": "price_label_size", "label": "Price Label Font Size", "default": "clamp(14px, 1.3vw, 16px)" },
    { "type": "text", "id": "price_size", "label": "Sale Price Font Size", "default": "clamp(24px, 3vw, 36px)" },

    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "left", "label": "Left (Image) / Right (Content)" },
        { "value": "right", "label": "Right (Image) / Left (Content)" }
      ],
      "default": "left"
    },
    { "type": "text", "id": "container_width", "label": "Container Max Width (px)", "default": "1400" }
  ],
  "blocks": [
    {
      "type": "checklist_item",
      "name": "Checklist Item",
      "settings": [
        { "type": "text", "id": "text", "label": "Item Text", "default": "NASM CPT - Certified Personal Trainer" }
      ]
    }
  ],
  "presets": [{
    "name": "HP Elite Bundle",
    "blocks": [
      { "type": "checklist_item", "settings": { "text": "NASM CPT - Certified Personal Trainer" } },
      { "type": "checklist_item", "settings": { "text": "NASM CNC - Certified Nutrition Coach" } },
      { "type": "checklist_item", "settings": { "text": "NASM PES - Performance Exercise Specialist" } },
      { "type": "checklist_item", "settings": { "text": "NASM CES - Corrective Exercise Specialist" } }
    ]
  }]
}
{% endschema %}

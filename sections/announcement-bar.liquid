{% comment %}
  Announcement Rotator (CSS-only) + Countdown Timer (JS)
  - Up to 4 rich-text announcements
  - Fade in/out via pure CSS (no JS for rotation)
  - Countdown uses tiny JS (needed for real time)
  - Optional NASM Official Canadian Partner badge on right
{% endcomment %}

{%- assign partner_on = section.settings.partner_enabled -%}

<section
  id="AnnouncementBar-{{ section.id }}"
  class="announcement-rotator-section count-{{ section.blocks.size }}{% if partner_on %} has-partner{% endif %}"
  style="
    --ann-speed: {{ section.settings.rotation_ms | default: 5000 }}ms;
    background: {{ section.settings.bg_color | default: '#C8FF63' }};
    color: {{ section.settings.text_color | default: '#000000' }};
    padding: {{ section.settings.padding_y | default: 12 }}px 0;
  "
>
  <div class="announcement-bar--container page-container">
    <div class="announcement-rotator" role="region" aria-live="polite">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'message' %}
          <div class="announcement" {{ block.shopify_attributes }}>
            <div class="rt">{{ block.settings.text }}</div>

            {% if section.settings.countdown_enabled %}
              <div
                class="ann-countdown"
                data-end="{{ section.settings.countdown_end }}"
                data-expired-text="{{ section.settings.countdown_expired_text | escape }}"
              >
                <span class="ann-countdown__label">{{ section.settings.countdown_label }}</span>
                <span class="ann-countdown__time" aria-live="polite"></span>
              </div>
            {% endif %}

            {% if block.settings.link_label != blank and block.settings.link_url != blank %}
              <a class="ann-link" href="{{ block.settings.link_url }}">{{ block.settings.link_label }}</a>
            {% endif %}
          </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="announcement">
          <div class="rt">🎉 FLASH SALE! BUY MORE, SAVE MORE!</div>

          {% if section.settings.countdown_enabled %}
            <div
              class="ann-countdown"
              data-end="{{ section.settings.countdown_end }}"
              data-expired-text="{{ section.settings.countdown_expired_text | escape }}"
            >
              <span class="ann-countdown__label">{{ section.settings.countdown_label }}</span>
              <span class="ann-countdown__time" aria-live="polite"></span>
            </div>
          {% endif %}

          <a class="ann-link" href="/collections/love-your-career">Shop now</a>
        </div>
      {% endif %}
    </div>

    {% if partner_on %}
      <div class="announcement-partner" aria-label="NASM Official Canadian Partner">
        {% if section.settings.partner_icon != blank %}
          <img
            class="announcement-partner__icon"
            src="{{ section.settings.partner_icon | image_url: width: 80 }}"
            alt=""
            loading="lazy"
            width="20"
            height="20">
        {% endif %}
        <span class="announcement-partner__text">{{ section.settings.partner_text }}</span>
      </div>
    {% endif %}
  </div>

  {% stylesheet %}
  #AnnouncementBar-{{ section.id }} .announcement-bar--container {
    display: flex; justify-content: center; align-items: center;
    padding: 0 12px;
    position: relative;
  }
  #AnnouncementBar-{{ section.id }}.has-partner .announcement-bar--container {
    justify-content: space-between;
    gap: 16px;
  }
  #AnnouncementBar-{{ section.id }} .announcement-rotator {
    display: grid;
    width: 100%;
  }
  #AnnouncementBar-{{ section.id }}.has-partner .announcement-rotator {
    flex: 1 1 auto;
  }
  #AnnouncementBar-{{ section.id }} .announcement {
    grid-area: 1 / 1;
    justify-self: center;
    margin: 0; text-align: center;
    opacity: 0; transform: translateY(6px);
  }
  #AnnouncementBar-{{ section.id }}.has-partner .announcement {
    justify-self: start;
    text-align: left;
  }
  #AnnouncementBar-{{ section.id }} .announcement a {
    color: #000;
    text-decoration: none;
  }
  #AnnouncementBar-{{ section.id }} .rt {
    font-family: 'Anton', var(--font-heading-family, var(--font-body-family));
    font-weight: 400; font-style: normal;
    font-size: {{ section.settings.font_size | default: 20 }}px;
    line-height: 100%;
    letter-spacing: 2px;
  }
  #AnnouncementBar-{{ section.id }} .rt p { margin: 0; }
  #AnnouncementBar-{{ section.id }} .rt p + p { margin-top: .25rem; }

  #AnnouncementBar-{{ section.id }} .ann-link {
    margin-left: .5ch;
    color: inherit;
    text-decoration: underline;
    font: inherit;
    white-space: nowrap;
  }

  #AnnouncementBar-{{ section.id }} .ann-countdown {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    justify-content: center;
    margin-top: 6px;
    font-family: var(--font-body-family);
    font-size: 14px;
    letter-spacing: 0.5px;
  }
  #AnnouncementBar-{{ section.id }} .ann-countdown__label {
    opacity: 0.9;
  }
  #AnnouncementBar-{{ section.id }} .ann-countdown__time {
    font-family: 'Anton', var(--font-heading-family, var(--font-body-family));
    letter-spacing: 1px;
  }

  /* NASM Official Canadian Partner */
  #AnnouncementBar-{{ section.id }} .announcement-partner {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex: 0 0 auto;
    font-family: 'Poppins', var(--font-body-family);
    font-size: {{ section.settings.partner_font_size | default: 'clamp(14px,1.6vw,16px)' }};
    color: {{ section.settings.partner_text_color | default: '#ffffff' }};
    letter-spacing: 0.5px;
    white-space: nowrap;
  }
  #AnnouncementBar-{{ section.id }} .announcement-partner__icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
    flex-shrink: 0;
  }

  @keyframes annFade {
    0%   { opacity: 0; transform: translateY(6px); }
    6%   { opacity: 1; transform: translateY(0); }
    28%  { opacity: 1; transform: translateY(0); }
    34%  { opacity: 0; transform: translateY(-6px); }
    100% { opacity: 0; transform: translateY(-6px); }
  }

  #AnnouncementBar-{{ section.id }}.count-0 .announcement:first-child,
  #AnnouncementBar-{{ section.id }}.count-1 .announcement:first-child {
    opacity: 1; transform: none;
  }

  #AnnouncementBar-{{ section.id }}.count-2 { --ann-cycle: calc(var(--ann-speed) * 2); }
  #AnnouncementBar-{{ section.id }}.count-2 .announcement { animation: annFade var(--ann-cycle) linear infinite both; }
  #AnnouncementBar-{{ section.id }}.count-2 .announcement:nth-child(1) { animation-delay: calc(var(--ann-speed) * 0); }
  #AnnouncementBar-{{ section.id }}.count-2 .announcement:nth-child(2) { animation-delay: calc(var(--ann-speed) * 1); }

  #AnnouncementBar-{{ section.id }}.count-3 { --ann-cycle: calc(var(--ann-speed) * 3); }
  #AnnouncementBar-{{ section.id }}.count-3 .announcement { animation: annFade var(--ann-cycle) linear infinite both; }
  #AnnouncementBar-{{ section.id }}.count-3 .announcement:nth-child(1) { animation-delay: calc(var(--ann-speed) * 0); }
  #AnnouncementBar-{{ section.id }}.count-3 .announcement:nth-child(2) { animation-delay: calc(var(--ann-speed) * 1); }
  #AnnouncementBar-{{ section.id }}.count-3 .announcement:nth-child(3) { animation-delay: calc(var(--ann-speed) * 2); }

  #AnnouncementBar-{{ section.id }}.count-4 { --ann-cycle: calc(var(--ann-speed) * 4); }
  #AnnouncementBar-{{ section.id }}.count-4 .announcement { animation: annFade var(--ann-cycle) linear infinite both; }
  #AnnouncementBar-{{ section.id }}.count-4 .announcement:nth-child(1) { animation-delay: calc(var(--ann-speed) * 0); }
  #AnnouncementBar-{{ section.id }}.count-4 .announcement:nth-child(2) { animation-delay: calc(var(--ann-speed) * 1); }
  #AnnouncementBar-{{ section.id }}.count-4 .announcement:nth-child(3) { animation-delay: calc(var(--ann-speed) * 2); }
  #AnnouncementBar-{{ section.id }}.count-4 .announcement:nth-child(4) { animation-delay: calc(var(--ann-speed) * 3); }

  @media (max-width: 640px) {
    #AnnouncementBar-{{ section.id }} .rt {
      font-size: {{ section.settings.font_size | default: 20 | minus: 2 }}px;
    }
    #AnnouncementBar-{{ section.id }} .announcement-partner__text {
      font-size: 11px;
      letter-spacing: 0.3px;
    }
    #AnnouncementBar-{{ section.id }} .announcement-partner__icon {
      width: 16px;
      height: 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #AnnouncementBar-{{ section.id }} .announcement { animation: none !important; }
    #AnnouncementBar-{{ section.id }}.count-2 .announcement:nth-child(1),
    #AnnouncementBar-{{ section.id }}.count-3 .announcement:nth-child(1),
    #AnnouncementBar-{{ section.id }}.count-4 .announcement:nth-child(1) { opacity: 1; transform: none; }
  }
  {% endstylesheet %}

  <script>
  (() => {
    const root = document.getElementById('AnnouncementBar-{{ section.id }}');
    if (!root) return;

    const timers = root.querySelectorAll('.ann-countdown');
    if (!timers.length) return;

    function parseEnd(endStr) {
      const normalized = (endStr || '').trim().replace(' ', 'T');
      const ms = Date.parse(normalized);
      return Number.isFinite(ms) ? ms : null;
    }

    function pad(n) { return String(n).padStart(2, '0'); }

    function formatRemaining(totalSeconds) {
      const days = Math.floor(totalSeconds / 86400);
      const hours = Math.floor((totalSeconds % 86400) / 3600);
      const mins = Math.floor((totalSeconds % 3600) / 60);
      const secs = totalSeconds % 60;

      if (days > 0) return `${days}d ${pad(hours)}h ${pad(mins)}m ${pad(secs)}s`;
      return `${pad(hours)}h ${pad(mins)}m ${pad(secs)}s`;
    }

    const config = Array.from(timers).map(el => {
      const endStr = el.getAttribute('data-end');
      const endMs = parseEnd(endStr);
      const expiredText = el.getAttribute('data-expired-text') || '';
      const timeEl = el.querySelector('.ann-countdown__time');
      return { el, endMs, expiredText, timeEl };
    });

    if (config.every(c => !c.endMs)) {
      config.forEach(c => c.el.style.display = 'none');
      return;
    }

    function tick() {
      const now = Date.now();

      config.forEach(c => {
        if (!c.endMs) {
          c.el.style.display = 'none';
          return;
        }

        const diff = Math.floor((c.endMs - now) / 1000);

        if (diff <= 0) {
          if (c.expiredText) {
            c.timeEl.textContent = c.expiredText;
          } else {
            c.el.style.display = 'none';
          }
        } else {
          c.timeEl.textContent = formatRemaining(diff);
        }
      });
    }

    tick();
    const interval = setInterval(() => {
      tick();
      const anyActive = Array.from(config).some(c => c.endMs && (c.endMs - Date.now()) > 0);
      if (!anyActive) clearInterval(interval);
    }, 1000);
  })();
  </script>
</section>

{% schema %}
{
  "name": "Announcement (rotating)",
  "tag": "section",
  "class": "section--announcement-bar",
  "max_blocks": 4,
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#C8FF63" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#000000" },
    { "type": "range", "id": "font_size", "label": "Font size", "min": 12, "max": 28, "step": 1, "unit": "px", "default": 20 },
    { "type": "range", "id": "padding_y", "label": "Top/bottom padding", "min": 0, "max": 48, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "rotation_ms", "label": "Rotation speed", "min": 1000, "max": 9000, "step": 250, "unit": "ms", "default": 5000 },

    { "type": "checkbox", "id": "countdown_enabled", "label": "Enable countdown", "default": true },
    { "type": "text", "id": "countdown_label", "label": "Countdown label", "default": "Ends in:" },
    { "type": "text", "id": "countdown_end", "label": "Countdown end (ISO with timezone)", "default": "2026-03-01T23:59:59+08:00" },
    { "type": "text", "id": "countdown_expired_text", "label": "Expired text (optional)", "default": "Sale ended" },

    { "type": "header", "content": "NASM Official Canadian Partner Badge" },
    { "type": "checkbox", "id": "partner_enabled", "label": "Show partner badge", "default": false },
    { "type": "image_picker", "id": "partner_icon", "label": "Partner icon" },
    { "type": "text", "id": "partner_text", "label": "Partner text", "default": "NASM OFFICIAL CANADIAN PARTNER" },
    { "type": "text", "id": "partner_font_size", "label": "Partner font size", "default": "clamp(14px,1.6vw,16px)" },
    { "type": "color", "id": "partner_text_color", "label": "Partner text color", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Announcement",
      "settings": [
        { "type": "richtext", "id": "text", "label": "Announcement text", "default": "<p>🎉 FLASH SALE! BUY MORE, SAVE MORE!</p>" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop now" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "presets": [{ "name": "Announcement (rotating)" }]
}
{% endschema %}

{%- assign sid = section.id -%}
{{ 'hp-sections.css' | asset_url | stylesheet_tag }}

<section id="hp-courses-{{ sid }}" class="hp-courses">
  <div class="hp-courses__inner">
    <div class="hp-courses__header">
      <h2 class="hp-courses__title">{{ section.settings.heading }}</h2>
      {%- if section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="hp-btn hp-btn--outline-dark">
          <span class="hp-btn__label">{{ section.settings.view_all_text | default: 'VIEW ALL COURSES' }}</span>
          <span class="hp-btn__label">{{ section.settings.view_all_text | default: 'VIEW ALL COURSES' }}</span>
        </a>
      {%- endif -%}
    </div>
    <p class="hp-courses__sub">{{ section.settings.subheading }}</p>

    <div class="hp-courses__grid">
      {%- for block in section.blocks -%}
        <div class="hp-courses__card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="hp-courses__card-img">
              <img
                src="{{ block.settings.image | image_url: width: 652 }}"
                srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                        {{ block.settings.image | image_url: width: 652 }} 652w"
                sizes="(max-width: 749px) 90vw, 30vw"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="326"
                height="375">
            </div>
          {%- endif -%}
          <h3 class="hp-courses__card-title">{{ block.settings.title }}</h3>
          {%- if block.settings.button_link != blank -%}
            <a href="{{ block.settings.button_link }}" class="hp-btn hp-btn--outline-dark hp-btn--sm">
              <span class="hp-btn__label">LEARN MORE</span>
              <span class="hp-btn__label">LEARN MORE</span>
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HP Top Courses",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Top Courses" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Explore our best selling courses trusted by trainers, built for your future." },
    { "type": "text", "id": "view_all_text", "label": "View All Text", "default": "VIEW ALL COURSES" },
    { "type": "url", "id": "view_all_link", "label": "View All Link" }
  ],
  "blocks": [
    {
      "type": "course",
      "name": "Course Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Course Image" },
        { "type": "text", "id": "title", "label": "Course Title", "default": "Certified Personal Trainer (CPT)" },
        { "type": "url", "id": "button_link", "label": "Learn More Link" }
      ]
    }
  ],
  "presets": [{
    "name": "HP Top Courses",
    "blocks": [
      { "type": "course", "settings": { "title": "Certified Personal Trainer (CPT)" } },
      { "type": "course", "settings": { "title": "Certified Nutrition Coach (CNC)" } },
      { "type": "course", "settings": { "title": "Certified Wellness Coach (CWC)" } }
    ]
  }]
}
{% endschema %}

{%- assign sid = section.id -%}
{{ 'hp-sections.css' | asset_url | stylesheet_tag }}

<section id="hp-courses-{{ sid }}" class="hp-courses">
  <div class="hp-courses__inner" style="max-width: {{ section.settings.container_width }}px;">
    <div class="hp-courses__header">
      <h2 class="hp-courses__title" style="font-size: {{ section.settings.title_size }}; color: {{ section.settings.title_color }};">{{ section.settings.heading }}</h2>
      {%- if section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="btn hp-btn-outline" style="font-size: {{ section.settings.btn_font_size }};">
          <span class="btn-label-down">{{ section.settings.view_all_text | default: 'VIEW ALL COURSES' }}</span>
          <span class="btn-label-down">{{ section.settings.view_all_text | default: 'VIEW ALL COURSES' }}</span>
        </a>
      {%- endif -%}
    </div>
    <p class="hp-courses__sub" style="font-size: {{ section.settings.body_size }}; color: {{ section.settings.body_color }};">{{ section.settings.subheading }}</p>

    <div class="hp-courses__grid">
      {%- for block in section.blocks -%}
        <div class="hp-courses__card" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="hp-courses__card-img">
              <img
                src="{{ block.settings.image | image_url: width: 652 }}"
                srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                        {{ block.settings.image | image_url: width: 652 }} 652w"
                sizes="(max-width: 749px) 90vw, 30vw"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="326"
                height="375">
            </div>
          {%- endif -%}
          <h3 class="hp-courses__card-title" style="font-size: {{ section.settings.card_title_size }}; color: {{ section.settings.title_color }};">{{ block.settings.title }}</h3>
          {%- if block.settings.button_link != blank -%}
            <a href="{{ block.settings.button_link }}" class="btn hp-btn-outline" style="font-size: {{ section.settings.btn_font_size }};">
              <span class="btn-label-down">LEARN MORE</span>
              <span class="btn-label-down">LEARN MORE</span>
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "HP Top Courses",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Top Courses" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Explore our best selling courses trusted by trainers, built for your future." },
    { "type": "text", "id": "view_all_text", "label": "View All Text", "default": "VIEW ALL COURSES" },
    { "type": "url", "id": "view_all_link", "label": "View All Link" },
    { "type": "header", "content": "Typography" },
    { "type": "text", "id": "title_size", "label": "Heading Font Size", "default": "clamp(28px, 3.8vw, 42px)" },
    { "type": "color", "id": "title_color", "label": "Heading Color", "default": "#141414" },
    { "type": "text", "id": "body_size", "label": "Body Font Size", "default": "clamp(14px, 1.4vw, 17px)" },
    { "type": "color", "id": "body_color", "label": "Body Color", "default": "#555555" },
    { "type": "text", "id": "card_title_size", "label": "Card Title Font Size", "default": "clamp(16px, 1.8vw, 22px)" },
    { "type": "text", "id": "btn_font_size", "label": "Button Font Size", "default": "14px" },
    { "type": "header", "content": "Layout" },
    { "type": "text", "id": "container_width", "label": "Container Max Width (px)", "default": "1400" }
  ],
  "blocks": [
    {
      "type": "course",
      "name": "Course Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Course Image" },
        { "type": "text", "id": "title", "label": "Course Title", "default": "Certified Personal Trainer (CPT)" },
        { "type": "url", "id": "button_link", "label": "Learn More Link" }
      ]
    }
  ],
  "presets": [{
    "name": "HP Top Courses",
    "blocks": [
      { "type": "course", "settings": { "title": "Certified Personal Trainer (CPT)" } },
      { "type": "course", "settings": { "title": "Certified Nutrition Coach (CNC)" } },
      { "type": "course", "settings": { "title": "Certified Wellness Coach (CWC)" } }
    ]
  }]
}
{% endschema %}

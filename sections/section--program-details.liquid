}
.product-button-wrap{
  margin-top:35px;
}
  
  .curriculum-sections .section-header button svg {
  width: 24px;
  height: 24px;
  vertical-align: middle; /* Adjust vertical alignment */
}
.curriculum-sections .section-header button {
  background-color: transparent;
  border: none;
  outline: none;
}

.curriculum {
  margin: 20px 0;
  background: #F8F8F8;
  padding: 20px 40px 40px;
  border-radius: 10px;
}
@media only screen and (max-width: 767px) {
  .curriculum {
    padding: 20px;
  }
}
.curriculum-section:first-child {
  border-bottom: 2px solid #0F828C;
}
.curriculum-section {
  border-bottom: 2px solid #B3B9B9;
}
.curriculum-sections .section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16px;
  cursor: pointer;
  padding: 20px 0;
}
.curriculum-sections .section-header__text{
  flex: 1;
  min-width: 0;
}
.section-header .metafield-rich_text_field p{
  margin: 0;
}
.section-header .metafield-rich_text_field p strong{
  display: block;
  margin-bottom: 6px;
}
.curriculum-sections .section-header h3 {
  margin: 0;
}
.curriculum-sections .section-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.5s ease-out, padding 0.5s ease-out;
}
.section-body.collapse {
  max-height: 2000px; 
  padding: 0 0 10px 0;
  transition: max-height 0.5s ease-out, padding 0.5s ease-out;
}
.program-details-container {
  display: flex;
  justify-content: space-between;
  gap:70px;
}


.program-details-h2{
  margin-top:0;
}
.details-column-right .section--title-block {
  padding: 0 40px;
}
@media only screen and (max-width: 767px) {
  .details-column-right .section--title-block {
    padding: 20px 20px 0;
  }
  .details-column-right .section--title-block h2 {
